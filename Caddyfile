:80 {
	# Support both deployment styles:
	# 1) Reverse proxy keeps the /coderaffy prefix
	# 2) Reverse proxy strips /coderaffy before forwarding to this container

	handle_path /coderaffy* {
		root * /srv/coderaffy
		try_files {path} /index.html
		file_server
	}

	handle {
		root * /srv/coderaffy
		try_files {path} /index.html
		file_server
	}
}
